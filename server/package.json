{
  "name": "server",
  "version": "1.0.0",
  "description": "Lakshmi gallery backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate-run.ts",
    "worker": "tsx src/worker/run.ts",
    "worker:prod": "node dist/src/worker/run.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.990.0",
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/client-sqs": "^3.1002.0",
    "@aws-sdk/cloudfront-signer": "^3.988.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.3",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "pg": "^8.13.1",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
