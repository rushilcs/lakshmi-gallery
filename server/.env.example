NODE_ENV=development
PORT=4000

# Database (Postgres; required)
DATABASE_URL=postgresql://user:password@localhost:5432/gallery

# Auth
SESSION_SECRET=change-this-session-secret
ADMIN_PASSWORD=change-me

# CORS (comma-separated; default http://localhost:5173 if empty)
ALLOWED_ORIGINS=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173

# AWS
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# Rekognition (optional; collection id prefix)
REKOGNITION_COLLECTION_ID_PREFIX=gallery

# SQS (optional; when set with NODE_ENV=production or FORCE_SQS=true, uses SQS instead of in-memory queue)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/lakshmi-gallery-jobs
# FORCE_SQS=true
